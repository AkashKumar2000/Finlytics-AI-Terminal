# ── AI / LLM ──────────────────────────────────────────────────

GROQ_API_KEY=your_groq_api_key_here

# ── External APIs ─────────────────────────────────────────────
# Get your free NewsAPI key at https://newsapi.org
# Used to fetch real-time financial news. App falls back to mock data if not set.
NEWS_API_KEY=your_newsapi_key_here

# Get your Tavily API key at https://app.tavily.com
# Used by the AI agent to search financial news. Required for news-based queries.
TAVILY_API_KEY=your_tavily_api_key_here

# ── Auth ──────────────────────────────────────────────────────
# Any long random string. Used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── Zerodha Kite Connect ──────────────────────────────────────
# Get these from https://developers.kite.trade after creating an app
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
# Access token expires daily — run: python scripts/kite_auth.py each morning to refresh
KITE_ACCESS_TOKEN=your_kite_access_token_here

# ── Database ──────────────────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/investdb
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/investdb
